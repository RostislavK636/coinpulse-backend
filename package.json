{
  "name": "coinpulse-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "db:up": "tsx scripts/db-up.ts",
    "dev": "ts-node src/server.ts",
    "bot": "tsx bot.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "node-telegram-bot-api": "^0.66.0",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
